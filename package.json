    "@typescript-eslint/eslint-plugin": "^6.5.1",
    "@typescript-eslint/parser": "^6.5.1",
    "eslint": "^8.45.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3",
    "@changesets/cli": "^2.27.9"
  }
}
