{
  "name": "express-route-cache",
  "version": "1.0.0",
  "description": "Type-safe, pluggable route-pattern caching middleware for Express.js",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.d.ts",
      "require": "./dist/types.d.ts",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "lint": "eslint . --ext .ts",
    "test:module": "node -e \"require('express-route-cache')\" && node --input-type=module -e \"import 'express-route-cache'\""
  },
  "keywords": [
    "express",
    "cache",
    "middleware",
    "typescript",
    "node-cache",
    "route-pattern"
  ],
  "author": "Yatharth Lakhate",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "node-cache": "^5.1.2"
  },
  "peerDependencies": {
    "express": "^4.17.1 || ^5.0.0"
  },
  "files": [
    "dist",
    "dist/esm"
  ]
}
