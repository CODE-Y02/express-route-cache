{
  "name": "@express-route-cache/core",
  "version": "0.2.0",
  "description": "Core caching functionality for Express routes",
  "author": "Yatharth Lakhate (https://code-y02.github.io/)",
  "license": "MIT",
  "homepage": "https://github.com/CODE-Y02/express-route-cache",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CODE-Y02/express-route-cache.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/CODE-Y02/express-route-cache/issues"
  },
  "keywords": [
    "express",
