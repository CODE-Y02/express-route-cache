    "@types/supertest": "^6.0.2",
    "express": "^5.1.0",
    "supertest": "^7.1.0",
    "tsup": "^8.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "lru-cache": "^11.2.6",
