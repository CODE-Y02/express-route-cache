{
  "name": "@express-route-cache/mcp",
  "version": "1.1.0",
  "description": "MCP server for @express-route-cache — gives Claude, Cursor, VS Code, and Windsurf live access to the documentation.",
  "author": "Yatharth Lakhate (https://code-y02.github.io/)",
  "license": "MIT",
  "homepage": "https://express-route-cache.js.org/guide/ai-support",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CODE-Y02/express-route-cache.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/CODE-Y02/express-route-cache/issues"
  },
  "keywords": [
    "express-route-cache",
    "mcp",
    "model-context-protocol",
    "express",
    "caching",
    "ai",
    "claude",
    "cursor"
  ],
  "type": "module",
  "bin": {
    "express-route-cache-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --no-splitting",
    "dev": "tsup src/index.ts --format esm --no-splitting --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
